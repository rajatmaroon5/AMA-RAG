# ============================================================
# AMA-RAG Backend - Environment Variables Reference
# ============================================================
# In Railway: set these in the service Variables tab.
# In Docker Compose: copy to .env in the project root.
# Format: Key=Value  (Railway uses __ as : separator for nested keys)
# ============================================================

# --- OpenAI ---
OpenAI__ApiKey=sk-your-openai-api-key

# --- Pinecone ---
Pinecone__ApiKey=your-pinecone-api-key
Pinecone__Environment=your-pinecone-environment
Pinecone__IndexName=ama-rag-index

# --- HuggingFace (optional) ---
HuggingFace__ApiKey=hf_your-huggingface-api-key

# --- SharePoint (optional) ---
SharePoint__ClientId=your-azure-app-client-id
SharePoint__ClientSecret=your-azure-app-client-secret
SharePoint__TenantId=your-azure-tenant-id

# --- CORS: space-separated list of allowed frontend origins ---
# Example: https://orange-sea-abc123.azurestaticapps.net
CORS_ALLOWED_ORIGINS=https://your-app.azurestaticapps.net

# --- Gmail MCP Bridge (optional) ---
# GmailMcp__PythonExecutable=python3
# GmailMcp__ScriptPath=/app/server.py
# GmailMcp__OAuthPort=8080

# --- Embedding Provider ---
Embedding__Provider=HuggingFace

# --- ASP.NET Core ---
ASPNETCORE_ENVIRONMENT=Production
