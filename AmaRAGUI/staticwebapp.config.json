{
  "navigationFallback": {
    "document": "/index.html",
    "exclude": ["/assets/*", "/*.{ico,png,jpg,js,css,woff,woff2}"]
  },
  "globalHeaders": {
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".json": "text/json"
  }
}
